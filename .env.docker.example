# Copy this file to .env, then replace local secrets. Never commit .env.

JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
SERVER_PORT=8081

# Local MySQL started by docker-compose.yml
SPRING_PROFILES_ACTIVE=mysql
DB_URL=jdbc:mysql://127.0.0.1:3306/aistudyhub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=123456
JPA_DDL_AUTO=update

# Used by Docker Compose. Keep these values synchronized with DB_* above.
MYSQL_DATABASE=aistudyhub
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306

UPLOAD_STORAGE_ROOT=uploads
AVATAR_STORAGE_DIR=uploads/avatars
DOCUMENT_STORAGE_DIR=uploads/documents

ADMIN_EMAIL=admin@studyhub.local
ADMIN_PASSWORD=Admin12345
ADMIN_FULL_NAME=StudyHub Admin

EXPOSE_RESET_TOKEN=true
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# Qwen 3.6 Flash through OpenRouter's OpenAI-compatible API.
AI_PROVIDER=openai
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_MODEL=qwen/qwen3.6-flash
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_OUTPUT_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=60

# Optional S3 document storage.
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional SMTP mail.
MAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
