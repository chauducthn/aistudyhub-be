# Local Docker MySQL settings for development.
# Copy the DB_* lines into .env when Railway DB is unavailable.

SPRING_PROFILES_ACTIVE=mysql
DB_URL=jdbc:mysql://127.0.0.1:3306/aistudyhub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=123456
JPA_DDL_AUTO=update

# Used by docker compose. Keep these in sync with DB_URL/DB_PASSWORD above.
MYSQL_DATABASE=aistudyhub
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306
