# Copy to .env and fill in real values (do not commit .env)

JWT_SECRET=change-this-to-a-long-secret-at-least-32-characters

# Use 8081 if port 8080 is blocked (e.g. Windows AgentService)
SERVER_PORT=8081

# MySQL profile (Railway)
SPRING_PROFILES_ACTIVE=mysql
DB_URL=jdbc:mysql://kodama.proxy.rlwy.net:55222/railway?useSSL=true&requireSSL=true&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_railway_mysql_password

JPA_DDL_AUTO=update

UPLOAD_STORAGE_ROOT=uploads
AVATAR_STORAGE_DIR=uploads/avatars
DOCUMENT_STORAGE_DIR=uploads/documents

ADMIN_EMAIL=admin@studyhub.local
ADMIN_PASSWORD=Admin12345
ADMIN_FULL_NAME=StudyHub Admin

EXPOSE_RESET_TOKEN=true
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# AI / Gemini chatbot
# Backend requires Gemini and does not fall back to local AI responses.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TIMEOUT_SECONDS=60

# AWS S3 document storage
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=aistudyhub-documents
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
