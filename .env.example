# Copy to .env and fill in real values (do not commit .env)

JWT_SECRET=change-this-to-a-long-secret-at-least-32-characters

# MySQL (local Docker)
DB_URL=jdbc:mysql://127.0.0.1:3306/aistudyhub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=123456

JPA_DDL_AUTO=update
MYSQL_DATABASE=aistudyhub
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306

UPLOAD_STORAGE_ROOT=uploads

ADMIN_EMAIL=admin@studyhub.local
ADMIN_PASSWORD=Admin12345
ADMIN_FULL_NAME=StudyHub Admin

EXPOSE_RESET_TOKEN=true
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# Optional Gmail SMTP configuration
MAIL_ENABLED=false
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_email@gmail.com

# Qwen chatbot
QWEN_API_KEY=your_openrouter_api_key
QWEN_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL=qwen/qwen3.6-flash
QWEN_TEMPERATURE=0.3
QWEN_MAX_OUTPUT_TOKENS=4096
QWEN_TIMEOUT_SECONDS=60

# Optional Gemini semantic retrieval. Keep disabled for the stable demo setup.
GEMINI_API_KEY=
RAG_EMBEDDING_ENABLED=false
RAG_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI-compatible chatbot
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_OUTPUT_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=60

# AWS S3 document storage
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=aistudyhub-documents
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
